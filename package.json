{
  "name": "stash-mcp-app",
  "version": "1.0.0",
  "private": true,
  "description": "AI-powered link manager built with Skybridge MCP framework",
  "type": "module",
  "scripts": {
    "dev": "dotenv -- skybridge dev",
    "build": "dotenv -- skybridge build",
    "start": "dotenv -- skybridge start",
    "deploy": "dotenv -- alpic deploy",
    "test": "dotenv -- vitest run",
    "test:watch": "dotenv -- vitest",
    "test:local": "dotenv -e .env -e .env.local -v TEST_ENV=local -- vitest run",
    "test:remote": "dotenv -e .env -e .env.local -v TEST_ENV=remote -- vitest run",
    "test:playground": "dotenv -e .env -e .env.local -v TEST_ENV=playground -- vitest run",
    "test:all": "npm run test:local && npm run test:remote && npm run test:playground"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "dotenv-cli": "^11.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "skybridge": ">=0.32.0 <1.0.0",
    "vite": "^7.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@skybridge/devtools": ">=0.32.0 <1.0.0",
    "@tailwindcss/postcss": "^4.2.0",
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "alpic": "^1.90.0",
    "autoprefixer": "^10.4.24",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=24.13.1"
  }
}
