# Alpic API Key (Required for deployment only)
# Get your API key from: https://app.alpic.ai
# 1. Sign in to your Alpic account
# 2. Click your team name → API Keys → New API key
# 3. Copy the key (you won't see it again!)
# Only needed for: npx alpic deploy
ALPIC_API_KEY=

# Remote deployment base URL (Required for testing remote/playground environments only)
# This is the URL where your app is deployed after running: npx alpic deploy
# Example: REMOTE_BASE_URL=https://your-app-abc123.alpic.live
# Only needed for: npm run test:remote and npm run test:playground
REMOTE_BASE_URL=

# Test environment selector (Optional - automatically set by npm scripts)
# Options: local, remote, or playground
# Defaults to 'local' if not set
# You usually don't need to set this manually - npm scripts handle it
TEST_ENV=local
